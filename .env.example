# ── API ключи для Hermes Agent ──────────────────
# Скопируй в ~/.hermes/.env и заполни

# Groq (основной провайдер subagent'ов) — бесплатно
# Получить: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key

# GitHub Models (бесплатный fallback gpt-4o-mini)
# Получить: https://github.com/settings/tokens (repo, gist права)
GITHUB_TOKEN=ghp_your_github_token

# OpenRouter (резерв для :free моделей)
# Получить: https://openrouter.ai/keys (пополнить от $5)
OPENROUTER_API_KEY=sk-or-v1_your_key
